# ============================================================
# Variables de entorno del SERVIDOR (Vercel Functions).
# En Vercel: Project → Settings → Environment Variables.
# Para local: copiá este archivo a .env y completá los valores.
# NUNCA subas el .env real al repositorio.
# ============================================================

# --- Supabase (validación del token en las funciones) ---
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=tu-anon-key

# --- Cloudinary (subida de PDF/imágenes) ---
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret
