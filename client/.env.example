# ============================================================
# Variables PÚBLICAS del cliente (Vite las expone en el navegador).
# Copiá este archivo a client/.env.local y completá los valores.
# En Vercel, definilas también como Environment Variables.
# ============================================================
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Cloudflare Turnstile (CAPTCHA en el login, anti fuerza bruta). OPCIONAL:
# si se deja vacío, el login funciona sin captcha. Pega aquí la SITE KEY
# (pública) del widget de Turnstile; la SECRET KEY va en Supabase.
VITE_TURNSTILE_SITE_KEY=
